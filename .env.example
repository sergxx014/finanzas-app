# ─────────────────────────────────────────────────────────────
# FinanzasApp — Variables de entorno
# Copia este archivo a .env y rellena los valores reales:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Sesión ────────────────────────────────────────────────────
# Genera un valor seguro con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CAMBIA_ESTE_VALOR_POR_UNO_ALEATORIO_DE_64_CARACTERES

# ── Cookie ────────────────────────────────────────────────────
# true solo si sirves la app por HTTPS (producción)
COOKIE_SECURE=false

# ── Base de datos MySQL ───────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finanzas
DB_USER=root
DB_PASS=CAMBIA_ESTE_PASSWORD_POR_UNO_FUERTE

# ── Email (reset de contraseña) ───────────────────────────────
# Para desarrollo usa Mailtrap: https://mailtrap.io
# Sandboxes → My Sandbox → SMTP → credenciales
# Si no se configura, solo fallará el flujo de reset de contraseña
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=tu_usuario_mailtrap
SMTP_PASS=tu_password_mailtrap
MAIL_FROM=noreply@finanzasapp.com

# ── URL pública de la app (usada en los enlaces de los emails) ─
# Con Docker (recomendado): http://localhost:3007
# Sin Docker (manual):      http://localhost:3000
APP_URL=http://localhost:3007
